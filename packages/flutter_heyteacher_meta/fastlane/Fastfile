# Uncomment the line if you want fastlane to automatically update itself
#update_fastlane

desc "fl build\n\tBuild flutter artifacts and rebuild pubspec.lock"
lane :build do
  Dir.chdir("../") do
    sh("rm -rf pubspec.lock")
    sh("flutter pub upgrade")
  end
end

desc "fl docweb\n\trun local webserver on generated doc"
lane :docweb do
  Dir.chdir("../") do
    # open browser http://localhost:8080 and run local webserver
    sh("dart pub global run dhttpd --path doc/api & open http://localhost:8080")
  end
end

desc "fl doc\n\tgenerate doc and run webserver"
lane :doc do
  Dir.chdir("../") do
    # generate doc
    sh("dart doc")
    # run local webserver
    docweb
  end
end

desc "fl test\n\tRun tests"
lane :test do
  Dir.chdir("../") do
    sh("flutter test")
  end
end

desc "fl checkout \n\tcheckout last branch created"
lane :checkout do
  puts "fetch repository getting output in gitFetch"
  gitFetch = sh("git fetch 2>&1 | grep branch")
  gitFetchLastLine= gitFetch.lines.last

  puts "get the branch name from #{gitFetchLastLine}"
  branch=gitFetchLastLine.split(" ")[3]

  puts "checkout branch #{branch} then pull"
  sh("git checkout #{branch}")
end

desc "fl release [version:major|minor|patch] [suffix:<nmenonic_tag_suffix>] [merge:true|false]\n\tCreates new release and merge branch into main"
lane :release do|options|
  if options[:merge] == nil || options[:merge] == true
    puts "create pull request"
    sh("gh pr create --fill-verbose")
    puts "wait 1 second in order new pull request will be available on github API"
    sleep(1)
    puts "merge pull request"
    sh("gh pr merge -m -d --auto")
  end
  puts "make release #{options[:version]} suffix #{options[:suffix]}"
  _make_release(
    options[:version], 
    options[:suffix], 
    true
  )
end

# release e version tagging in git 
# Params:
# +version+:: semver (major|minor|patch)
# +suffix+:: mnemonic tag suffix (may be nil)
# +create_github_release+:: if true, create a github release (true|false)
def _make_release(version, suffix, create_github_release)
  increment_flutter_build_number
  test
  tag = ""
  Dir.chdir("../") do
    tag = sh("dart run flutter_heyteacher_fastlane:version #{version}")
    # append tag suffix if set
    if suffix != nil && suffix != ""
      tag = "#{tag}_#{suffix}"
    end
  end
  # commit bump and push remote
  sh("git pull")
  puts "commit pubspec.yaml"
  sh("git branch tag")
  sh("git checkout tag")
  sh("git add -f ../pubspec.*")
  sh("git commit -m \"build(deps): bump deps version to #{tag}\"")
  sh("git checkout main")
  sh("git merge tag")
  sh("git branch tag -d")
  push_to_git_remote
  # generate a release
  if create_github_release == nil || create_github_release == true
    create_github_release(tag)
  else 
    # add tag and puth remote
    puts "create tag #{tag}"
    add_git_tag(tag: tag)
    push_git_tags(tag: tag)
  end
end

# create a git hub release
# Params:
# +name+:: the release name
# +suffix+:: mnemonic tag suffix (may be nil)
# +create_github_release+:: if true, create a github release (true|false)
def create_github_release(name)
  puts "create github release #{name}"
  sh("gh release create #{name} --generate-notes")
  puts "wait 1 second in order new release will be available on github API"
  sleep(1)
  Dir.chdir("../") do
    puts "generate CHANGELOG.md changelog-from-release"
    changelog_content = sh("changelog-from-release")
    puts "write CHANGELOG.md with changelog-from-release output"
    changelog_file = File.open('CHANGELOG.md','w') 
    changelog_file.write(changelog_content) 
    changelog_file.close() 
    puts "CHANGELOG.md updated"
  end 
  sh("git branch release")
  sh("git checkout release")
  puts "commit CHANGELOG.md with release #{name}"
  git_commit(path: "CHANGELOG.md", message: "docs: update CHANGELOG.md with release #{name}")
  sh("git checkout main")
  sh("git merge release")
  sh("git branch release -d")
  push_to_git_remote
end

def increment_flutter_build_number 
  Dir.chdir("../") do
    sh("dart run flutter_heyteacher_fastlane:version build")
  end
end